    "opencode",
    "opencode-plugin",
    "latex",
    "tex",
    "formatter"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.5",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
